# Copy this file to ".env" (same folder) and fill in what you use.
# ".env" is private and never committed. Paste secrets HERE, never into the chat.
# You don't need everything at once — fill in a section when you set that tool up.

# --- n8n (your automations) ---
# Instance base URL, NO trailing /api/v1.  e.g. https://yourname.app.n8n.cloud
N8N_API_URL=
# n8n -> Settings -> n8n API -> Create an API key
N8N_API_KEY=

# --- Pipedrive (CRM) — optional ---
# Just the part before .pipedrive.com  (e.g. "acme" for acme.pipedrive.com)
PIPEDRIVE_DOMAIN=
# Pipedrive -> Settings -> Personal preferences -> API
PIPEDRIVE_API_TOKEN=

# --- Supabase (cloud memory) — optional, see supabase/README.md ---
# Project Settings -> API -> Project URL  (e.g. https://xxxx.supabase.co)
SUPABASE_URL=
# Project Settings -> API -> service_role key (private; machine-only)
SUPABASE_KEY=
# Namespace for this project's memory in the cloud (any short label)
PROJECT_ID=project

# --- Anthropic (only if a skill calls the API directly) — optional ---
ANTHROPIC_API_KEY=
